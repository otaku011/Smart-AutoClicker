<resources>

    <string name="item_title_tutorial_text_conditions_moving_text">检测屏幕上的移动文字</string>
    <string name="item_desc_tutorial_text_conditions_moving_text">学习如何创建事件以点击随机移动的文字</string>
    <string name="message_game_tutorial_text_conditions_moving_text">只点击"Hello"按钮，尽可能快</string>

    <string name="message_tutorial_text_conditions_moving_text_step_1">欢迎来到移动文字条件教程！\n\n在这里，你将借助Klick\'r挑战
        游戏的最高分。\n\n你可以先按下开始游戏来试玩，
        也可以直接进行场景配置。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_2">与其他任何屏幕条件一样，我们首先需要
        创建一个屏幕事件。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_3">现在，单击条件字段以打开条件列表。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_4">我们需要创建条件。点击创建。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_5">在本教程中，我们想学习如何检测
        屏幕上的文字，所以请选择文本条件</string>

    <string name="message_tutorial_text_conditions_moving_text_step_6">文本条件由要检测的文字和
        屏幕搜索区域来定义。\n\n由于我们想在游戏按钮显示"Hello"时点击它，请在
        检测文字字段中输入Hello。</string>
    <string name="message_tutorial_text_conditions_moving_text_step_secondary_6">字母表字段定义了要检测文字的书写系统。
        "Hello"使用拉丁字母，因此这里可以保持默认值，但检测非拉丁文字时不要忘记
        更改它。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_7">现在我们需要告诉Klick\'r在哪里搜索
        文字。\n\n点击检测区域选择器来定义它。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_8">调整检测矩形的位置和大小，使其
        覆盖四个按钮，因为"Hello"会随机出现在这4个位置中的任意一个。区域正确后，按验证按钮保存。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_secondary_8">和往常一样，尽量使用尽可能小的检测框，
        同时在要检测的文字周围保留一定边距。区域越小，检测速度越快。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_9">你的条件现在已配置好！\n\n还有几项
        调整可以进行，但默认设置已适合我们的基本用例。\n\n单击保存按钮进行注册，然后返回条件列表。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_10">关闭条件列表，返回事件配置。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_11">有了这个条件，场景就知道何时触发操作了。\n\n
        现在你需要定义触发哪些操作，对于这个游戏，就是点击"Hello"按钮。\n\n单击操作字段，
        显示操作列表。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_12">操作是在其事件的条件满足时执行的内容。\n\n
        可以是点击、滑动、暂停、Intent（与其他应用的交互）或
        场景执行中的变化，同一个事件可以定义多个操作。\n\n点击创建操作按钮以创建你的第一个操作。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_13">首先，我们需要为你的操作选择一个类型。\n\n对于这个游戏，我们只需
        点击按钮，所以选择点击来创建新的点击操作。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_14">由于"Hello"在移动，我们无法使用
        固定位置。将"点击位置"设置更改为"条件"，以点击检测到的条件位置。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_15">点击条件选择器以选择要点击的检测条件。
        \n\n我们需要指定它，因为一个事件可以有多个条件。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_16">对于我们的用例来说很容易，我们只有一个条件，即文字"Hello"。
        \n\n选择它以在屏幕上检测到此条件时单击它。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_17">就是这样！\n你的点击操作现在已经正确配置以打赢比赛。\n\n单击保存按钮注册并返回操作列表。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_18">关闭操作列表，返回事件配置。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_19">你的事件现在有一个条件和一个操作，这意味着它知道何时执行什么。
        \n\n点击保存按钮以保存它并返回场景对话框。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_20">场景的唯一要求是至少有一个事件。\n由于我们的事件已经涵盖了如何赢得比赛，
        我们不需要其他任何东西。\n\n点击保存按钮以将场景保存在数据库中并关闭配置对话框。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_21">正如你所看到的，播放按钮现在可用，这意味着你的场景有效并且可以用于检测。
        \n\n点击它以开始检测。</string>

    <string name="message_tutorial_text_conditions_moving_text_step_22">正在运行但什么都没发生？\n\n这是正常的，它只会在
        按钮显示"Hello"时才点击，还记得吗？在保持场景运行的同时，按下开始游戏按钮
        然后看Klick\'r替你赢得比赛！</string>

    <string name="message_tutorial_text_conditions_moving_text_step_23">恭喜！\n\n你现在知道如何检测屏幕上显示的移动文字了。
        \n查看其他教程以发现更多用例。</string>
</resources>
